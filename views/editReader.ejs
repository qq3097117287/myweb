<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>编辑读者</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    body {
        background: linear-gradient(135deg, #e0e7ff 0%, #f0f4ff 100%);
        min-height: 100vh;
        font-family: "Microsoft Yahei",sans-serif;
    }
    .form-box{
        background: #fff;
        border-radius:15px;
        box-shadow: 0 4px 20px rgba(41, 121, 255, 0.1);
        padding:30px;
        margin-top:15px;
    }
    .page-title{
        color:#1c3b70;
        border-left:5px solid #2979ff;
        padding-left:15px;
        font-weight:600;
    }
    .navbar-custom {
        background: linear-gradient(135deg, #1c3b70 0%, #2979ff 100%) !important;
    }
</style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-custom navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="/adminIndex">
            <i class="bi bi-book-half"></i> 📚 智慧图书管理系统
        </a>
        <div class="d-flex align-items-center text-white">
            <span><i class="bi bi-person-check"></i> 欢迎：<%=user.username%>【管理员】</span>
            <a href="/logout" class="btn btn-outline-light btn-sm ms-3">
                <i class="bi bi-box-arrow-right"></i> 退出
            </a>
        </div>
    </div>
</nav>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a href="/readerList" class="btn btn-outline-primary mt-4">
                <i class="bi bi-arrow-left"></i> 返回读者列表
            </a>
            <h3 class="page-title mt-3">👤 编辑读者信息</h3>
            <div class="form-box">
                <form action="/updateReader" method="post">
                    <input type="hidden" name="id" value="<%=reader.id%>">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">读者姓名 <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="read_name" value="<%=reader.read_name%>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">学号/工号</label>
                            <input type="text" class="form-control" name="student_id" value="<%=reader.student_id || ''%>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">电话</label>
                            <input type="text" class="form-control" name="phone" value="<%=reader.phone || ''%>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">邮箱</label>
                            <input type="email" class="form-control" name="email" value="<%=reader.email || ''%>">
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg"></i> 保存修改
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>