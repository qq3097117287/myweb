<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>我的借阅</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
            min-height: 100vh;
            font-family: "Microsoft Yahei",sans-serif;
        }
        .table-container {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(76, 175, 80, 0.1);
        }
        .table thead th {
            background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
            color: #fff;
            border: none;
            text-align: center;
            font-weight: 500;
            padding: 15px 12px;
        }
        .table td {
            text-align: center;
            vertical-align: middle;
            padding: 12px;
        }
        .page-title {
            color: #1b5e20;
            border-left: 5px solid #4caf50;
            padding-left: 15px;
            font-weight: 600;
        }
        .navbar-custom {
            background: linear-gradient(135deg, #2e7d32 0%, #4caf50 100%) !important;
        }
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 500;
        }
        .status-borrowing {
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
            color: white;
        }
        .status-returned {
            background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
            color: white;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-custom navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="/readerIndex">
            <i class="bi bi-book-half"></i> 📚 图书系统【读者】
        </a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/readerIndex"><i class="bi bi-book"></i> 图书阅览</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="/myBorrow"><i class="bi bi-journal-bookmark"></i> 我的借阅</a>
                </li>
            </ul>
            <div class="d-flex align-items-center text-white">
                <span><i class="bi bi-person-check"></i> 欢迎：<%=user.username%></span>
                <a href="/logout" class="btn btn-outline-light btn-sm ms-3">
                    <i class="bi bi-box-arrow-right"></i> 退出
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="container" style="padding: 20px 0;">
    <h3 class="page-title mb-4">📋 我的借阅记录</h3>

    <!-- 借阅记录列表 -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>图书名称</th>
                        <th>借阅日期</th>
                        <th>归还日期</th>
                        <th>状态</th>
                    </tr>
                </thead>
                <tbody>
                <% list.forEach(item => { %>
                <tr>
                    <td><strong><%=item.book_name%></strong></td>
                    <td><%=new Date(item.borrow_date).toLocaleDateString()%></td>
                    <td>
                        <% if(item.back_date) { %>
                            <%=new Date(item.back_date).toLocaleDateString()%>
                        <% } else { %>
                            <span class="text-muted">-</span>
                        <% } %>
                    </td>
                    <td>
                        <% if(item.back_date) { %>
                            <span class="status-badge status-returned">
                                <i class="bi bi-check-circle"></i> 已归还
                            </span>
                        <% } else { %>
                            <span class="status-badge status-borrowing">
                                <i class="bi bi-clock"></i> 借阅中
                            </span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>

        <% if(list.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size: 48px;"></i>
            <p class="mt-3">暂无借阅记录</p>
        </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>